# --- Dependencias ---
# pnpm usa pnpm-lock.yaml, pero los módulos no se suben
node_modules/
.pnpm-debug.log*

# --- Directorios de Build (Vite) ---
dist/
dist-ssr/
*.local

# --- Docker ---
# No es estrictamente necesario ignorar estos, pero sí los datos persistentes
# si decides mapear una carpeta de base de datos localmente.
.docker/
# Si usas archivos de variables de entorno (MUY IMPORTANTE)
.env
.env.local
.env.*.local

# --- IDEs / Editores (Windows & VS Code) ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Logs y Debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# --- Sistema Operativo ---
Thumbs.db
Desktop.ini
.DS_Store